# ═══════════════════════════════════════════════════════════════
# ARC (Agent Remote Control) — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Port for the relay server
PORT=8600

# Agent authentication token. Agents must present this to register.
# If not set, the server auto-generates one and logs it at startup.
# AGENT_TOKEN=your-strong-random-token

# Comma-separated allowed CORS origins (default: * for local dev)
# ALLOWED_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# Require TLS for WebSocket connections (default: false for local dev)
# REQUIRE_TLS=true

# Session configuration
MAX_TRACE_LOG=2000
MAX_SESSIONS=100
MAX_VIEWERS_PER_SESSION=10
SESSION_TTL_HOURS=24
