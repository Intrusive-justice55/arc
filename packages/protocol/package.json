{
  "name": "@axolotlai/arc-protocol",
  "version": "0.1.0",
  "description": "Core protocol types for agent remote control",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/axolotl-ai-cloud/arc.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./base-adapter": {
      "types": "./dist/base-adapter.d.ts",
      "import": "./dist/base-adapter.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "import": "./dist/crypto.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0"
  }
}
